# Heygen API
HEYGEN_API_KEY=your_heygen_api_key
HEYGEN_BASE_URL=https://api.heygen.com

# Petya backend — base URL (no trailing slash). ilianaaiAvatar prepends paths like
# /api/v1/avatar/config and /api/v1/avatar/conversations/:conversationId/status
# Examples: http://localhost:5000 (local) | https://api.yourdomain.com (production)
PETYA_BASE_URL=https://your-petya-backend.com

# Shared secret for Petya updateConversationStatus (must match Petya's AVATAR_SERVICE_SECRET)
AVATAR_SERVICE_SECRET=your_shared_secret

# Optional: MongoDB if writing directly (Petya handles DB writes by default)
# MONGODB_URI=mongodb://localhost:27017/petya

# Server
PORT=3000

# Optional: CORS origin for production (e.g. your WordPress origin). Use * for local dev.
# CORS_ORIGIN=http://localhost:8080
