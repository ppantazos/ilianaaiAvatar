LIVEAVATAR_API_KEY=your_liveavatar_api_key_here

# Session mode: LITE (reliable) or FULL (avatar talks - session/start may fail)
LIVEAVATAR_MODE=LITE

# Optional: Defaults for session token. Client request body overrides these when provided.
LIVEAVATAR_AVATAR_ID=
LIVEAVATAR_CONTEXT_ID=
LIVEAVATAR_VOICE_ID=
LIVEAVATAR_LANGUAGE=en

PORT=3000
CORS_ORIGIN=*