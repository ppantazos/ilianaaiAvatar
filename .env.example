# =============================================================================
# ilianaaiAvatar — Production Environment Variables
# Copy to .env and fill in values before deploying.
# Run `npm run list:avatars` to get avatar IDs (no Heygen dashboard needed).
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Heygen API
# -----------------------------------------------------------------------------
# API key from Heygen (Space Settings > API). Same key used by Petya.
HEYGEN_API_KEY=

# Heygen API base URL. Usually leave as-is.
HEYGEN_BASE_URL=https://api.heygen.com

# -----------------------------------------------------------------------------
# REQUIRED: Avatar config (used when client doesn't send avatar_id)
# -----------------------------------------------------------------------------
# Run `npm run list:avatars` to see available avatar IDs.
DEFAULT_AVATAR_ID=

# Optional: Heygen knowledge base ID for avatar responses
# DEFAULT_KNOWLEDGE_BASE_ID=

# Optional: Heygen voice ID
# DEFAULT_VOICE_ID=

# Optional: Greeting text shown when chat starts
# DEFAULT_INTRO=Hello! How can I help you today?

# -----------------------------------------------------------------------------
# REQUIRED for production: CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (e.g. your WordPress domain).
# Example: https://yoursite.com,https://www.yoursite.com
# Use * only for local development.
CORS_ORIGIN=

# -----------------------------------------------------------------------------
# OPTIONAL: Petya integration (transcript persistence)
# -----------------------------------------------------------------------------
# ilianaaiAvatar calls Petya when sessions end. Petya writes to MongoDB. ilianaaiAvatar never writes to DB directly.
# PETYA_BASE_URL=
# AVATAR_SERVICE_SECRET=

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port. Many platforms (Railway, Render) set this automatically.
PORT=3000
